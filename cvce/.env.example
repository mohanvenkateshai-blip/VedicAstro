# VedicAstro CVCE — runtime configuration.
# Copy to `.env` for local dev; in production set these as real env vars.
# No secrets belong in this file.

# --- Server ---
CVCE_HOST=0.0.0.0
CVCE_PORT=8400

# --- CORS allowlist (comma-separated). MUST be set to the portal origin(s)
#     in production. Defaults below are local dev only. ---
CVCE_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# --- Calculation ---
CVCE_DEFAULT_AYANAMSA=LAHIRI
# Divisional charts (Shodashvarga) included in /chart. Comma-separated D-numbers.
CVCE_VARGAS=1,2,3,4,7,9,10,12,16,24,30,60

# --- Rate limiting (per client IP) ---
CVCE_RATE_LIMIT_REQUESTS=60
CVCE_RATE_LIMIT_WINDOW=60
